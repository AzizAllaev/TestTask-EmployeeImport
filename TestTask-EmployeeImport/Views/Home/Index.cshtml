@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <div class="container mt-5">
        <h2>Employee Import</h2>

        <form asp-controller="Home" asp-action="UploadCsv" method="post" enctype="multipart/form-data" class="mb-4">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="file" class="form-label">Select CSV File:</label>
                        <input type="file" name="file" class="form-control" accept=".csv" required />
                    </div>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Execute Import</button>
                </div>
            </div>
        </form>

        <div id="gridContainer">
        </div>
    </div>
</div>

@model IEnumerable<Employee>

<div class="mt-4">
    <table id="employeesTable" class="table table-striped table-bordered" style="width:100%">
        <thead>
            <tr>
                <th>Payroll #</th>
                <th>Forenames</th>
                <th>Surname</th>
                <th>Date of Birth</th>
                <th>Telephone</th>
                <th>Mobile</th>
                <th>Address</th>
                <th>Address 2</th>
                <th>Postcode</th>
                <th>Email (Home)</th>
                <th>Start Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var emp in Model)
                {
                    <tr>
                        <td>@emp.Payroll_Number</td>
                        <td>@emp.Forenames</td>
                        <td>@emp.Surname</td>
                        <td>@emp.Date_of_Birth.ToShortDateString()</td>
                        <td>@emp.Telephone</td>
                        <td>@emp.Mobile</td>
                        <td>@emp.Address</td>
                        <td>@emp.Adress2</td>
                        <td>@emp.Postcode</td>
                        <td>@emp.EMail_Home</td>
                        <td>@emp.Start_Date</td>
                        <td>
                            <a class="btn btn-sm btn-warning">Edit</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#employeesTable').DataTable({
                "order": [[2, "asc"]],
                "scrollX": true,
            });
        });
    </script>
}